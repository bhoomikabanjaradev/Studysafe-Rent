<% layout('layouts/boilerplate') -%>
<div class="row mt-5">
    <div class="col-8 offset-2"> 
     <h3>Create a new listings</h3>
    <form method="POST" action="/listings" >
        
        <div class="md-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" placeholder="Add a cathcy Title" class="form-control">
        </div>
        <div class="md-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control"></textarea>
        </div>
        
        <div class="md-3">
            <label for="image" class="form-label">Image URL</label>
            <input type="text" name="listing[image]" placeholder="enter image URL/Link" class="form-control">
   
        </div>
        
        <div class="row">
            <div class="md-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input type="number" name="listing[price]" placeholder="1200" class="form-control">
            </div>

            <div class="md-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listing[country]" placeholder="India" class="form-control">
            </div>
        </div>


        
            <div class="md-3">
                <label for="location" class="form-label">Location</label>
                <input type="text" name="listing[location]" placeholder="jaipur, Rajasthan" class="form-control">
            </div>
        
        
        <br>
        <br>

        <button class="btn btn-dark add-btn mt-3" >Add</button>
        </div>
    </form>
    </div>
